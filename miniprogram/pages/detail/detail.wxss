/* 详情页样式 */

page {
  background: #F0F2F5;
}

.container {
  padding: 20rpx 24rpx;
}

/* 顶部算法信息栏 */
.info-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.info-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.info-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E50;
}

.info-difficulty {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.diff-easy {
  background: #E8F8EF;
  color: #27AE60;
}

.diff-medium {
  background: #FEF3E0;
  color: #E67E22;
}

.diff-hard {
  background: #FDEDEC;
  color: #E74C3C;
}

.info-right {
  font-size: 26rpx;
  color: #7F8C8D;
  font-family: monospace;
  font-weight: 500;
}

/* Canvas 区域 */
.canvas-area {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.canvas {
  width: 100%;
  height: 460rpx;
}

/* ====== 控制区域 ====== */
.controls {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* 进度条 */
.progress-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.progress-bar {
  flex: 1;
  height: 10rpx;
  background: #ECF0F1;
  border-radius: 5rpx;
  position: relative;
  overflow: visible;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90D9, #5B9FE0);
  border-radius: 5rpx;
  transition: width 0.15s ease;
}

.progress-dot {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 24rpx;
  background: #FFFFFF;
  border: 3rpx solid #4A90D9;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(74, 144, 217, 0.3);
  transition: left 0.15s ease;
}

.progress-text {
  font-size: 22rpx;
  color: #95A5A6;
  font-family: monospace;
  min-width: 90rpx;
  text-align: right;
}

/* 按钮组 */
.btn-group {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 24rpx;
}

.control-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  background: #F8F9FA;
  transition: all 0.2s;
  min-width: 100rpx;
}

.control-btn:active {
  background: #ECF0F1;
  transform: scale(0.95);
}

.primary-btn {
  background: #4A90D9;
  min-width: 120rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

.primary-btn.playing {
  background: #E67E22;
  box-shadow: 0 4rpx 16rpx rgba(230, 126, 34, 0.3);
}

.primary-btn:active {
  transform: scale(0.96);
}

.btn-icon {
  font-size: 28rpx;
  line-height: 1;
}

.primary-btn .btn-icon {
  font-size: 32rpx;
}

.btn-label {
  font-size: 20rpx;
  color: #95A5A6;
}

.primary-btn .btn-label {
  color: #FFFFFF;
  font-weight: 500;
}

/* 算法说明卡片 */
.info-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 16rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #5D6D7E;
  line-height: 1.8;
  display: block;
  margin-bottom: 24rpx;
}

.card-steps {
  background: #F8F9FA;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.step-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 16rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.step-item:last-child {
  margin-bottom: 0;
}

.step-num {
  width: 36rpx;
  height: 36rpx;
  background: #4A90D9;
  color: #FFFFFF;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-text {
  font-size: 26rpx;
  color: #5D6D7E;
  line-height: 1.5;
  flex: 1;
  padding-top: 4rpx;
}

/* 复杂度卡片 */
.complexity-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.comp-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.comp-label {
  font-size: 22rpx;
  color: #95A5A6;
}

.comp-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
  font-family: monospace;
}

.comp-divider {
  width: 2rpx;
  height: 50rpx;
  background: #ECF0F1;
}
