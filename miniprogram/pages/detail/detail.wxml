<!--详情页 - Canvas 可视化 + 控制面板-->
<view class="container">
  <!-- 解锁遮罩层（进阶算法未解锁时显示） -->
  <view class="lock-overlay" wx:if="{{showLock}}" bindtap="preventTap">
    <view class="lock-box">
      <text class="lock-icon">🔒</text>
      <text class="lock-title">进阶算法</text>
      <text class="lock-desc">观看 15 秒小广告\n即可免费解锁学习</text>
      <view class="lock-btn" bindtap="unlockByAd">
        <text>📺 观看广告解锁</text>
      </view>
      <view class="lock-close" bindtap="goBack">
        <text>返回</text>
      </view>
    </view>
  </view>

  <!-- 顶部算法信息 -->
  <view class="info-bar">
    <view class="info-left">
      <text class="info-name">{{algorithm.name}}</text>
      <text class="info-difficulty {{algorithm.difficulty === '入门' ? 'diff-easy' : algorithm.difficulty === '进阶' ? 'diff-medium' : 'diff-hard'}}">{{algorithm.difficulty}}</text>
      <!-- 已解锁标记 -->
      <text wx:if="{{algorithm.difficulty === '进阶' && !showLock}}" class="unlocked-badge">✅ 已解锁</text>
    </view>
    <view class="info-right">
      <text class="info-complexity">{{algorithm.timeComplexity}}</text>
    </view>
  </view>

  <!-- Canvas 可视化区域 -->
  <view class="canvas-area">
    <canvas
      type="2d"
      id="vizCanvas"
      class="canvas"
    ></canvas>
  </view>

  <!-- 播放控制 -->
  <view class="controls">
    <!-- 进度条 -->
    <view class="progress-wrap">
      <view class="progress-bar" bindtouchstart="onProgressStart" bindtouchmove="onProgressMove" bindtouchend="onProgressEnd">
        <view class="progress-fill" style="width: {{progressPercent}}%"></view>
        <view class="progress-dot" style="left: {{progressPercent}}%"></view>
      </view>
      <text class="progress-text">{{currentStep + 1}} / {{totalSteps}}</text>
    </view>

    <!-- 按钮组 -->
    <view class="btn-group">
      <view class="control-btn" bindtap="reset">
        <text class="btn-icon">⏮</text>
        <text class="btn-label">重置</text>
      </view>
      <view class="control-btn" bindtap="stepBackward">
        <text class="btn-icon">◀</text>
        <text class="btn-label">上一步</text>
      </view>
      <view class="control-btn primary-btn {{isPlaying ? 'playing' : ''}}" bindtap="togglePlay">
        <text class="btn-icon">{{isPlaying ? '⏸' : '▶'}}</text>
        <text class="btn-label">{{isPlaying ? '暂停' : '播放'}}</text>
      </view>
      <view class="control-btn" bindtap="stepForward">
        <text class="btn-icon">▶</text>
        <text class="btn-label">下一步</text>
      </view>
      <view class="control-btn" bindtap="setSpeed">
        <text class="btn-icon">🐢</text>
        <text class="btn-label">{{speed}}x</text>
      </view>
    </view>
  </view>

  <!-- 算法说明卡片 -->
  <view class="info-card">
    <view class="card-title">📖 算法说明</view>
    <text class="card-desc">{{algorithm.description}}</text>

    <view class="card-steps">
      <view class="step-title">执行步骤</view>
      <view class="step-item" wx:for="{{algorithm.steps}}" wx:key="*this" wx:for-item="step">
        <text class="step-num">{{index + 1}}</text>
        <text class="step-text">{{step}}</text>
      </view>
    </view>
  </view>

  <!-- 复杂度卡片 -->
  <view class="complexity-card">
    <view class="comp-item">
      <text class="comp-label">时间复杂度</text>
      <text class="comp-value">{{algorithm.timeComplexity}}</text>
    </view>
    <view class="comp-divider"></view>
    <view class="comp-item">
      <text class="comp-label">空间复杂度</text>
      <text class="comp-value">{{algorithm.spaceComplexity}}</text>
    </view>
    <view wx:if="{{algorithm.stable !== null}}" class="comp-divider"></view>
    <view wx:if="{{algorithm.stable !== null}}" class="comp-item">
      <text class="comp-label">稳定性</text>
      <text class="comp-value">{{algorithm.stable ? '✅ 稳定' : '❌ 不稳定'}}</text>
    </view>
  </view>

  <!-- 广告位（调试用测试ID，上线后替换为真实ID） -->
  <view class="ad-wrap">
    <ad unit-id="adunit-7fca7715e8e1c92f" bindload="onAdLoad" binderror="onAdError" style="width:100%;display:block;"></ad>
  </view>

  <!-- 底部间距 -->
  <view style="height: 40rpx;"></view>
</view>
