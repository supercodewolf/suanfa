/* 首页样式 */

page {
  background: #F0F2F5;
}

.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
}

/* 顶部标题 */
.header {
  text-align: center;
  padding: 40rpx 0 30rpx;
}

.header-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 10rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2C3E50;
  display: block;
}

.header-subtitle {
  font-size: 26rpx;
  color: #95A5A6;
  margin-top: 8rpx;
  display: block;
}

/* 分类卡片 */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.category-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  border-left: 8rpx solid var(--card-color);
}

.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  cursor: pointer;
}

.category-header:active {
  background: #F8F9FA;
}

.category-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.category-icon {
  font-size: 36rpx;
}

.category-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C3E50;
}

.category-count {
  font-size: 24rpx;
  color: #BDC3C7;
  background: #F0F2F5;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.arrow {
  color: #95A5A6;
  font-size: 28rpx;
  transition: transform 0.3s;
  display: inline-block;
}

.arrow.expanded {
  transform: rotate(180deg);
}

/* 算法列表 */
.algo-list {
  overflow: hidden;
  max-height: 0;
  transition: max-height 0.35s ease;
}

.algo-list.expanded {
  max-height: 2000rpx;
}

.algo-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #F0F2F5;
  transition: background 0.2s;
}

.algo-item:active {
  background: #F0F7FF;
}

.algo-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.algo-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #2C3E50;
}

.algo-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.algo-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.tag-easy {
  background: #E8F8EF;
  color: #27AE60;
}

.tag-medium {
  background: #FEF3E0;
  color: #E67E22;
}

.tag-hard {
  background: #FDEDEC;
  color: #E74C3C;
}

.algo-complexity {
  font-size: 22rpx;
  color: #95A5A6;
  font-family: monospace;
}

/* 右侧预览 */
.algo-arrow-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.algo-preview-bar {
  display: flex;
  align-items: flex-end;
  gap: 3rpx;
  height: 50rpx;
}

.mini-bar {
  width: 6rpx;
  border-radius: 3rpx;
  background: #BDC3C7;
}

.arrow-right {
  font-size: 36rpx;
  color: #BDC3C7;
  font-weight: 300;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  margin-top: 40rpx;
  color: #BDC3C7;
  font-size: 24rpx;
}
