/* 首页样式 - WeUI 风格 */
.page {
  padding-bottom: 40rpx;
}

.page__hd {
  text-align: center;
  padding: 40rpx 30rpx 30rpx;
}

.page__title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2C3E50;
}

.page__desc {
  font-size: 26rpx;
  color: #95A5A6;
  margin-top: 10rpx;
}

.page__bd {
  padding: 0 24rpx;
}

.page__ft {
  text-align: center;
  padding: 30rpx 0;
}

.arrow-icon {
  display: inline-block;
  transition: transform 0.3s;
}

.arrow-icon.rotated {
  transform: rotate(180deg);
}

/* WeUI 微调 */
.weui-panel {
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.weui-panel__hd {
  padding: 0;
  border-radius: 16rpx 16rpx 0 0;
}

.weui-media-box {
  padding: 20rpx 30rpx;
}

.weui-media-box:active {
  background: #F0F7FF;
}
